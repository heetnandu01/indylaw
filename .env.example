# IndyLaw API — Environment Variables
# Copy this file to server/.env and fill in your values.
# Never commit server/.env to version control.

# Your Resend API key — get it from https://resend.com/api-keys
RESEND_API_KEY=re_9djKKPX2_PwUBs9ysAXa1osRJYeAMoz1G

# Email address that receives admin notifications on every demo request
ADMIN_EMAIL=admin@indylaw.in

# Sender address shown in emails.
# Use onboarding@resend.dev for local testing (no DNS setup needed).
# For production, verify your own domain in the Resend dashboard.
FROM_EMAIL=admin@indylaw.in

# Port for the Express API server
PORT=3000
